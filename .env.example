# App
NEXTAUTH_URL=https://winsproposal.com
NEXTAUTH_SECRET=replace-with-32-plus-random-characters

# Database
# Use the pooled Neon connection string in Vercel unless you have a reason to use the direct connection.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# AWS S3 storage
AWS_REGION=us-east-1
AWS_BUCKET_NAME=winsproposal-production
S3_BUCKET_NAME=winsproposal-production
AWS_FOLDER_PREFIX=
AWS_ACCESS_KEY_ID=replace-with-iam-access-key
AWS_SECRET_ACCESS_KEY=replace-with-iam-secret-key
S3_ACCESS_KEY_ID=replace-with-iam-access-key
S3_SECRET_ACCESS_KEY=replace-with-iam-secret-key
# AWS_SESSION_TOKEN=

# Transitional AI/PDF/email integrations still used by the current app.
# Replace these with independent providers before fully removing Abacus runtime dependencies.
ABACUSAI_API_KEY=
WEB_APP_ID=
NOTIF_ID_DEMO_REQUEST_SUBMISSION=
NOTIF_ID_TEAM_INVITE=

# Optional build controls
# NEXT_DIST_DIR=.next
# NEXT_OUTPUT_MODE=
